# Docker PostgreSQL/PostGIS Configuration
# Apple Silicon (M1/M2/M3/M4) users can use the experimental multi-arch image:
# POSTGRES_IMAGE=imresamu/postgis:18-3.6-alpine
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=modulith_demo

# Optional: Custom port for PostgreSQL
DB_PORT=5432

# Optional: Custom port for Valkey
VALKEY_PORT=6379
