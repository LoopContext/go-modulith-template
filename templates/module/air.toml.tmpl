root = "."
testdata_dir = "testdata"
tmp_dir = "bin"

[build]
  args_bin = []
  bin = "./bin/{{.MODULE_NAME}}"
  cmd = "go build -o ./bin/{{.MODULE_NAME}} ./cmd/{{.MODULE_NAME}}"
  delay = 1000
  exclude_dir = ["assets", "bin", "vendor", "testdata", "deployment", "docs", ".github", "gen"]
  exclude_file = []
  exclude_regex = ["_test.go"]
  exclude_unchanged = false
  follow_symlink = false
  full_bin = ""
  include_ext = ["go", "tpl", "tmpl", "html", "yaml", "yml", "proto", "sql", "env"]
  include_file = [".env", "configs/server.yaml", "configs/{{.MODULE_NAME}}.yaml"]
  kill_delay = "0s"
  log = "build-errors.log"
  poll = false
  poll_interval = 0
  rerun = false
  rerun_delay = 500
  send_interrupt = false
  stop_on_error = true

[log]
  main_only = false
  time = false

[color]
  app = ""
  build = "yellow"
  main = "magenta"
  runner = "green"
  watcher = "cyan"

[misc]
  clean_on_exit = false

[screen]
  clear_on_rebuild = false
  keep_scroll = true

