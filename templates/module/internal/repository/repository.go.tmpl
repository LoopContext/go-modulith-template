// Package repository provides the data access layer for the {{.MODULE_NAME}} module.
package repository

import (
	"context"
	"database/sql"
	"fmt"

	"{{.PROJECT_NAME}}/modules/{{.MODULE_NAME}}/internal/db/store"
)

// Repository is the interface for the {{.MODULE_NAME}} module data access.
type Repository interface {
	WithTx(ctx context.Context, fn func(Repository) error) error
	Create{{.MODULE_NAME_CAPITALIZED}}(ctx context.Context, id, name string) error
	Get{{.MODULE_NAME_CAPITALIZED}}(ctx context.Context, id string) (*store.{{.MODULE_STRUCT_NAME}}, error)
}

// SQLRepository implements the Repository interface using SQL.
type SQLRepository struct {
	q  *store.Queries
	db *sql.DB
}

// NewSQLRepository creates a new instance of SQLRepository.
func NewSQLRepository(db *sql.DB) *SQLRepository {
	return &SQLRepository{
		q:  store.New(db),
		db: db,
	}
}

// WithTx executes the given function within a database transaction.
func (r *SQLRepository) WithTx(ctx context.Context, fn func(Repository) error) error {
	tx, err := r.db.BeginTx(ctx, nil)
	if err != nil {
		return fmt.Errorf("failed to begin transaction: %w", err)
	}

	defer func() {
		if p := recover(); p != nil {
			_ = tx.Rollback()
			panic(p)
		} else if err != nil {
			_ = tx.Rollback()
		} else {
			err = tx.Commit()
		}
	}()

	txRepo := &SQLRepository{
		q:  r.q.WithTx(tx),
		db: r.db,
	}

	err = fn(txRepo)
	return err
}

// Create{{.MODULE_NAME_CAPITALIZED}} creates a new {{.MODULE_NAME}} record.
func (r *SQLRepository) Create{{.MODULE_NAME_CAPITALIZED}}(ctx context.Context, id, name string) error {
	if err := r.q.Create{{.MODULE_NAME_CAPITALIZED}}(ctx, store.Create{{.MODULE_NAME_CAPITALIZED}}Params{
		ID:   id,
		Name: name,
	}); err != nil {
		return fmt.Errorf("failed to create {{.MODULE_NAME}}: %w", err)
	}

	return nil
}

// Get{{.MODULE_NAME_CAPITALIZED}} retrieves a {{.MODULE_NAME}} record by its ID.
// Note: SQLC returns structs (not pointers), so we convert to pointer here.
func (r *SQLRepository) Get{{.MODULE_NAME_CAPITALIZED}}(ctx context.Context, id string) (*store.{{.MODULE_STRUCT_NAME}}, error) {
	result, err := r.q.Get{{.MODULE_NAME_CAPITALIZED}}(ctx, id)
	if err != nil {
		return nil, fmt.Errorf("error getting {{.MODULE_NAME}}: %w", err)
	}

	return &result, nil
}
