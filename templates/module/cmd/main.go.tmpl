// Package main is the entry point for the {{.MODULE_NAME}} service.
package main

import (
	"context"
	"database/sql"
	"fmt"
	"log/slog"
	"net"
	"net/http"
	"os"
	"os/signal"
	"syscall"
	"time"

	"google.golang.org/grpc/reflection"
	"google.golang.org/protobuf/encoding/protojson"

	"{{.PROJECT_NAME}}/internal/authn"
	"{{.PROJECT_NAME}}/internal/config"
	"{{.PROJECT_NAME}}/internal/events"
	"{{.PROJECT_NAME}}/internal/migration"
	"{{.PROJECT_NAME}}/internal/notifier"
	"{{.PROJECT_NAME}}/internal/registry"
	"{{.PROJECT_NAME}}/internal/swagger"
	"{{.PROJECT_NAME}}/internal/websocket"
	"{{.PROJECT_NAME}}/modules/{{.MODULE_NAME}}"
	"github.com/grpc-ecosystem/grpc-gateway/v2/runtime"
	_ "github.com/jackc/pgx/v5/stdlib"
	"github.com/joho/godotenv"
	"go.opentelemetry.io/contrib/instrumentation/google.golang.org/grpc/otelgrpc"
	"google.golang.org/grpc"
	"google.golang.org/grpc/credentials/insecure"
)

func main() {
	ctx, stop := signal.NotifyContext(context.Background(), os.Interrupt, syscall.SIGTERM)
	defer stop()

	// Load configuration
	systemEnvVars := captureSystemEnvVars()
	_ = godotenv.Load()

	cfg, err := config.Load("configs/{{.MODULE_NAME}}.yaml", systemEnvVars)
	if err != nil {
		slog.Error("Failed to load config", "error", err)
		return
	}

	// Initialize database
	db, err := sql.Open("pgx", cfg.DBDSN)
	if err != nil {
		slog.Error("Failed to open DB", "error", err)
		return
	}
	defer db.Close()

	if err := db.Ping(); err != nil {
		slog.Error("Failed to ping DB", "error", err)
		return
	}

	// Create registry
	reg := createRegistry(cfg, db)

	// Register module
	reg.Register({{.MODULE_NAME}}.NewModule())

	// Initialize module
	if err := reg.InitializeAll(); err != nil {
		slog.Error("Failed to initialize module", "error", err)
		return
	}

	// Run migrations
	runner := migration.NewRunner(cfg.DBDSN, reg)
	if err := runner.RunAll(); err != nil {
		slog.Error("Failed to run migrations", "error", err)
		return
	}

	// Setup gRPC server
	grpcServer, lis, err := setupGRPC(cfg, reg)
	if err != nil {
		slog.Error("Failed to setup gRPC server", "error", err)
		return
	}

	// Setup HTTP gateway
	mux, gatewayConn, err := setupGateway(ctx, cfg, reg)
	if err != nil {
		_ = lis.Close()
		slog.Error("Failed to setup gateway", "error", err)
		return
	}

	// Start HTTP server
	httpServer := startHTTPServer(cfg, mux)

	// Start gRPC server
	go func() {
		slog.Info("Starting {{.MODULE_NAME}} gRPC server", "port", cfg.GRPCPort)
		if err := grpcServer.Serve(lis); err != nil {
			slog.Error("failed to serve gRPC", "error", err)
			stop()
		}
	}()

	<-ctx.Done()
	shutdownServers(cfg, httpServer, grpcServer, gatewayConn)
}

func createRegistry(cfg *config.AppConfig, db *sql.DB) *registry.Registry {
	ebus := events.NewBus()
	wsHub := websocket.NewHub(context.Background())
	ntf := notifier.NewLogNotifier()

	// Initialize subscribers
	wsSubscriber := websocket.NewSubscriber(wsHub, ebus)
	wsSubscriber.Subscribe()

	ns := notifier.NewSubscriber(ntf)
	ns.SubscribeToEvents(ebus)

	go wsHub.Run()

	return registry.New(
		registry.WithConfig(cfg),
		registry.WithDatabase(db),
		registry.WithEventBus(ebus),
		registry.WithNotifier(ntf),
		registry.WithWebSocketHub(wsHub),
	)
}

func setupGRPC(cfg *config.AppConfig, reg *registry.Registry) (*grpc.Server, net.Listener, error) {
	lis, err := net.Listen("tcp", fmt.Sprintf(":%s", cfg.GRPCPort))
	if err != nil {
		return nil, nil, fmt.Errorf("failed to listen gRPC: %w", err)
	}

	verifier, err := authn.NewJWTVerifier(cfg.Auth.JWTSecret)
	if err != nil {
		_ = lis.Close()
		return nil, nil, fmt.Errorf("failed to init jwt verifier: %w", err)
	}

	// Get public endpoints from module
	public := reg.GetPublicEndpoints()

	grpcServer := grpc.NewServer(
		grpc.StatsHandler(otelgrpc.NewServerHandler()),
		grpc.ChainUnaryInterceptor(authn.UnaryServerInterceptor(authn.InterceptorConfig{
			Verifier:      verifier,
			PublicMethods: public,
		})),
	)

	reg.RegisterGRPCAll(grpcServer)
	reflection.Register(grpcServer)

	return grpcServer, lis, nil
}

func setupGateway(ctx context.Context, cfg *config.AppConfig, reg *registry.Registry) (*http.ServeMux, *grpc.ClientConn, error) {
	rmux := runtime.NewServeMux(
		runtime.WithMarshalerOption(runtime.MIMEWildcard, &runtime.JSONPb{
			MarshalOptions: protojson.MarshalOptions{
				EmitUnpopulated: true,
				UseProtoNames:   true,
			},
		}),
	)

	// Create gRPC connection for gateway
	conn, err := grpc.NewClient(
		fmt.Sprintf("127.0.0.1:%s", cfg.GRPCPort),
		grpc.WithTransportCredentials(insecure.NewCredentials()),
	)
	if err != nil {
		return nil, nil, fmt.Errorf("failed to dial gRPC server: %w", err)
	}

	// Register module with gateway
	if err := reg.RegisterGatewayAll(ctx, rmux, conn); err != nil {
		_ = conn.Close()
		return nil, nil, fmt.Errorf("failed to register gateway: %w", err)
	}

	mux := http.NewServeMux()
	mux.Handle("/", rmux)

	// Setup health checks
	mux.HandleFunc("/healthz", func(w http.ResponseWriter, _ *http.Request) {
		w.WriteHeader(http.StatusOK)
		_, _ = w.Write([]byte("OK"))
	})

	mux.HandleFunc("/readyz", func(w http.ResponseWriter, r *http.Request) {
		if err := reg.DB().PingContext(r.Context()); err != nil {
			w.WriteHeader(http.StatusServiceUnavailable)
			_, _ = w.Write([]byte("Disconnected"))
			return
		}
		w.WriteHeader(http.StatusOK)
		_, _ = w.Write([]byte("Ready"))
	})

	// Setup Swagger UI (dev only, not prod)
	if cfg.Env == "dev" {
		swagger.SetupForModule(mux, "{{.MODULE_NAME}}")
	}

	return mux, conn, nil
}

func startHTTPServer(cfg *config.AppConfig, mux *http.ServeMux) *http.Server {
	server := &http.Server{
		Addr:              fmt.Sprintf(":%s", cfg.HTTPPort),
		Handler:           mux,
		ReadHeaderTimeout: 5 * time.Second,
	}

	go func() {
		slog.Info("Starting {{.MODULE_NAME}} HTTP server", "port", cfg.HTTPPort)
		if err := server.ListenAndServe(); err != nil && err != http.ErrServerClosed {
			slog.Error("failed to serve HTTP", "error", err)
		}
	}()

	return server
}

func shutdownServers(cfg *config.AppConfig, httpServer *http.Server, grpcServer *grpc.Server, gatewayConn *grpc.ClientConn) {
	slog.Info("Shutting down {{.MODULE_NAME}} server")

	shutdownCtx, cancel := context.WithTimeout(context.Background(), 10*time.Second)
	defer cancel()

	if gatewayConn != nil {
		_ = gatewayConn.Close()
	}

	if err := httpServer.Shutdown(shutdownCtx); err != nil {
		slog.Error("Failed to shutdown HTTP server", "error", err)
	}

	grpcServer.GracefulStop()
	slog.Info("{{.MODULE_NAME}} server shutdown complete")
}

func captureSystemEnvVars() map[string]string {
	systemEnvVars := make(map[string]string)
	if env := os.Getenv("ENV"); env != "" {
		systemEnvVars["ENV"] = env
	}
	if port := os.Getenv("GRPC_PORT"); port != "" {
		systemEnvVars["GRPC_PORT"] = port
	}
	if dsn := os.Getenv("DB_DSN"); dsn != "" {
		systemEnvVars["DB_DSN"] = dsn
	}
	if secret := os.Getenv("JWT_SECRET"); secret != "" {
		systemEnvVars["JWT_SECRET"] = secret
	}
	return systemEnvVars
}

